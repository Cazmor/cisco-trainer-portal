PORT=3000
NODE_ENV=development

JWT_SECRET=replace-with-a-secure-random-secret
JWT_EXPIRY=7d
CORS_ORIGIN=
UPLOAD_PATH=uploads

# Supabase Postgres is the recommended database.
# Use the pooled connection string from Supabase when possible.
# DATABASE_URL=postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres
DB_SSL=true

# Or use individual Supabase values instead of DATABASE_URL:
# DB_HOST=aws-0-region.pooler.supabase.com
# DB_PORT=6543
# DB_NAME=postgres
# DB_USER=postgres.project-ref
# DB_PASSWORD=your-supabase-password

# Local development fallback:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=cisco_tracker
# DB_USER=postgres
# DB_PASSWORD=postgres123
# DB_SSL=false
